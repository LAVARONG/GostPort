# ==========================================
# GostPort 环境变量配置 (.env.example)
# ==========================================

# [网络配置]
# 管理面板绑定的IP。默认是 127.0.0.1 (仅本机访问)
# 如果要开放给外网/局域网访问，请修改为 0.0.0.0
WEB_HOST=0.0.0.0

# 管理面板端口，默认 8080
WEB_PORT=8080

# 大网IP (外网公开访问的IP)。配置此项后，面板上的 0.0.0.0 会自动被替换为此IP，方便点击一键复制
# EXTERNAL_IP=1.1.1.1

# [安全认证]
# 开启 BasicAuth 网页认证（留空这两项参数则为无密码直接访问面板，极简模式）
WEB_USERNAME=admin
# 建议修改为高强度密码
WEB_PASSWORD=your_secure_password
